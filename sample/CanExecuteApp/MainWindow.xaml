<Window
    x:Class="CanExecuteApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:CanExecuteApp"
    mc:Ignorable="d"
    Title="CanExecute 샘플"
    Width="480"
    Height="560"
    Background="#F5F5F7">

    <Window.Resources>
        <!-- 공통 버튼 스타일 -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Opacity="{TemplateBinding Opacity}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 제목 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock
                FontSize="22"
                FontWeight="Bold"
                Foreground="#1D1D1F"
                Text="Todo List" />
            <TextBlock
                Margin="0,4,0,0"
                FontSize="12"
                Foreground="#8E8E93"
                Text="CanExecute 패턴 3가지 데모" />
        </StackPanel>

        <!-- 입력 영역: 패턴 2 — 파라미터 있는 메서드 + 파라미터 있는 CanExecute -->
        <Border
            Grid.Row="1"
            Margin="0,0,0,16"
            Background="White"
            CornerRadius="12"
            Padding="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,8,0">
                    <TextBox
                        x:Name="InputBox"
                        Padding="8,6"
                        FontSize="14"
                        BorderThickness="1"
                        BorderBrush="#E5E5EA"
                        VerticalContentAlignment="Center"
                        KeyDown="InputBox_KeyDown" />
                    <TextBlock
                        x:Name="Placeholder"
                        IsHitTestVisible="False"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="#AAAAAA"
                        Text="할 일을 입력하세요...">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=InputBox, Path=Text}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- AddCommand: Command<string> — 비어있으면 자동으로 비활성화 -->
                <Button
                    Grid.Column="1"
                    Background="#007AFF"
                    Command="{Binding AddCommand}"
                    CommandParameter="{Binding ElementName=InputBox, Path=Text}"
                    Content="추가"
                    Style="{StaticResource PrimaryButton}" />
            </Grid>
        </Border>

        <!-- 목록 -->
        <Border
            Grid.Row="2"
            Background="White"
            CornerRadius="12"
            Padding="4">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08" />
            </Border.Effect>
            <ListBox
                ItemsSource="{Binding State.Items}"
                BorderThickness="0"
                Background="Transparent"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="12,10" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Border" Background="Transparent">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Ellipse
                                                Grid.Column="0"
                                                Width="8" Height="8"
                                                Margin="4,0,10,0"
                                                VerticalAlignment="Center"
                                                Fill="#007AFF" />
                                            <ContentPresenter
                                                Grid.Column="1"
                                                VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#F2F2F7" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock FontSize="14" Foreground="#1D1D1F" Text="{Binding}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- 액션 버튼 영역 -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ClearAllCommand: 필드 + bool 프로퍼티 CanExecute (수정된 버그 케이스) -->
            <Button
                Grid.Column="0"
                Background="#FF3B30"
                Command="{Binding ClearAllCommand}"
                Content="전체 삭제"
                Style="{StaticResource PrimaryButton}" />

            <!-- ExportCommand: 필드 + 파라미터 없는 메서드 CanExecute -->
            <Button
                Grid.Column="2"
                Background="#34C759"
                Command="{Binding ExportCommand}"
                Content="{Binding IsLoading, Converter={x:Static local:BoolToStringConverter.Instance},
                          ConverterParameter='내보내는 중...|내보내기'}"
                Style="{StaticResource PrimaryButton}" />
        </Grid>

        <!-- 상태 메시지 -->
        <TextBlock
            Grid.Row="4"
            Margin="0,12,0,0"
            HorizontalAlignment="Center"
            FontSize="12"
            Foreground="#8E8E93"
            Text="{Binding State.Status}" />

        <!-- CanExecute 설명 패널 -->
        <Border
            Grid.Row="4"
            Margin="0,36,0,0"
            Background="#F2F2F7"
            CornerRadius="10"
            Padding="12">
            <StackPanel>
                <TextBlock FontSize="11" FontWeight="Bold" Foreground="#8E8E93" Text="생성된 코드 패턴" Margin="0,0,0,6"/>
                <TextBlock FontSize="11" Foreground="#636366" TextWrapping="Wrap"
                           Text="추가: Command&lt;string&gt;(CreateAdd, CanAdd)" />
                <TextBlock FontSize="11" Foreground="#636366" TextWrapping="Wrap"
                           Text="전체 삭제: Command(_clearAll, () =&gt; CanClearAll)" />
                <TextBlock FontSize="11" Foreground="#636366" TextWrapping="Wrap"
                           Text="내보내기: AsyncCommand(_export, CanExport)" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
